{
    "compilerOptions": {
      "rootDir": "./src",
      "outDir": "./dist",
  
      "module": "nodenext",
      "target": "esnext",
  
      "sourceMap": true,
      "noEmitOnError": true,
  
      "strict": true,
      "noUncheckedIndexedAccess": true,
      "exactOptionalPropertyTypes": true,
  
      "verbatimModuleSyntax": true,
      "isolatedModules": true,
      "noUncheckedSideEffectImports": true,
      "moduleDetection": "force",
  
      "skipLibCheck": true
    },
    "ts-node": {
      "esm": true,
      "experimentalSpecifierResolution": "node"
    }
  }