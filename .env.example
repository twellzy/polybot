# Required
TARGET_WALLET=0x00
PRIVATE_KEY=0x00
FUNDER_WALLET=00
RPC_URL=

# Optional geo token (if provided by Polymarket for your account/region)
POLYMARKET_GEO_TOKEN=

# Trading
POSITION_MULTIPLIER=0.1
MAX_TRADE_SIZE=3
MIN_TRADE_SIZE=1
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=FOK

#Copied trades will be calculated as a proportion of this value and the original trade value
#Trades will then be made as a percentage of the max trade size according to the original size
TRADE_CEILING=100

# Risk (0 disables the cap)
MAX_SESSION_NOTIONAL=0
MAX_PER_MARKET_NOTIONAL=0

# Monitoring
USE_WEBSOCKET=true
USE_USER_CHANNEL=false
POLL_INTERVAL=4000
WS_ASSET_IDS=
WS_MARKET_IDS=

# Optional gas floor overrides for Polygon approval/order txs
MIN_PRIORITY_FEE_GWEI=30
MIN_MAX_FEE_GWEI=60